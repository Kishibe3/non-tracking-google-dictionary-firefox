{
    "name": "Non-Tracking Google Dictionary",
    "version": "0",
    "description": "translate unfamiliar words",
    "manifest_version": 3,
    "icons": {
        "100": "icon.png"
    },
    "permissions": [
        "activeTab",
        "contextMenus"
    ],
    
    "action": {
        "default_title": "Translate Words",
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": ["https://*/*", "http://*/*"],
            "js": ["content.js"]
        }
    ],
    "background": {
        "scripts": ["background.js"]
    },
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+Alt+D"
            },
            "description": "Open extension serach bar"
        }
    }
}
